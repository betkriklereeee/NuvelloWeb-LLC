RewriteEngine On

# Redirect /index and /index.html to root /
RewriteRule ^index(\.html)?$ / [R=301,L]

# Serve services.html when /services or /services/ is requested
RewriteRule ^services/?$ /services.html [L]

# Redirect .html URLs to clean versions (301 for SEO)
RewriteCond %{THE_REQUEST} \s/+([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve .html files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]